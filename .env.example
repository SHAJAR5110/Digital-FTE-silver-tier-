# Silver Tier - Credentials & Configuration
# DO NOT COMMIT THIS FILE TO GIT
# Copy to .env and fill in your values

---

# VAULT CONFIGURATION
VAULT_PATH=/c/Users/HP/Desktop/H/FTEs/Silver Tier/AI_Employee_Vault

---

# GMAIL WATCHER

# Option A: Using OAuth2 (Recommended)
GMAIL_CREDENTIALS_PATH=~/.secrets/gmail_credentials.json
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly

# Gmail API project credentials
GMAIL_CLIENT_ID=your_client_id_from_google_cloud.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REDIRECT_URI=http://localhost:8888/

# Gmail account to monitor
GMAIL_USER_EMAIL=your_email@gmail.com
GMAIL_CHECK_INTERVAL=120  # Seconds (every 2 minutes)

---

# WHATSAPP WATCHER

# Option A: Browser-based (Playwright)
WHATSAPP_SESSION_PATH=~/.secrets/whatsapp_session
WHATSAPP_CHECK_INTERVAL=30  # Seconds

# Option B: Official API (if available)
WHATSAPP_BUSINESS_PHONE_ID=your_phone_id
WHATSAPP_BUSINESS_ACCESS_TOKEN=your_access_token

---

# LINKEDIN WATCHER

# Option A: Email/Password (Unofficial API)
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password
LINKEDIN_SESSION_PATH=~/.secrets/linkedin_session
LINKEDIN_CHECK_INTERVAL=300  # Seconds (every 5 minutes)

# Option B: Official API (requires business account)
LINKEDIN_ACCESS_TOKEN=your_access_token
LINKEDIN_CLIENT_ID=your_client_id
LINKEDIN_CLIENT_SECRET=your_client_secret

---

# EMAIL SENDING (MCP SERVER)

# Provider selection
EMAIL_PROVIDER=gmail  # Options: gmail, smtp, sendgrid

# Option A: Gmail API
EMAIL_GMAIL_CREDENTIALS_PATH=~/.secrets/gmail_email_credentials.json
EMAIL_GMAIL_USER=your_email@gmail.com

# Option B: SMTP (Gmail, Outlook, Custom)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password  # NOT your regular password!
SMTP_FROM_NAME=Your Name

# Option C: SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key

# Email configuration
EMAIL_CHECK_INTERVAL=60
EMAIL_MAX_RETRIES=3

---

# LINKEDIN POSTING (MCP SERVER)

# OAuth tokens for posting
LINKEDIN_POSTING_ACCESS_TOKEN=your_access_token
LINKEDIN_POSTING_PERSON_ID=your_person_id
LINKEDIN_POSTING_ORGANIZATION_ID=your_organization_id

# LinkedIn verification
LINKEDIN_POSTING_USER_EMAIL=your_email@example.com

---

# CLAUDE CODE SCHEDULING

# How often Claude runs
CLAUDE_RUN_INTERVAL=1800  # 30 minutes in seconds

# Python/pip paths (if needed)
PYTHON_PATH=python3
PIP_PATH=pip3

# Vault relative to this directory
VAULT_RELATIVE_PATH=AI_Employee_Vault

---

# PROXY/VPN (Optional)

# If behind proxy
HTTP_PROXY=http://proxy.company.com:8080
HTTPS_PROXY=https://proxy.company.com:8080
NO_PROXY=localhost,127.0.0.1

---

# LOGGING

# Log level
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Log file
LOG_FILE=~/.logs/silver_tier.log

# Log rotation
LOG_MAX_SIZE=10485760  # 10MB

---

# SECURITY

# Session security
SESSION_TIMEOUT=3600  # 1 hour in seconds
REQUIRE_APPROVAL_FOR_EXTERNAL=true

# Rate limiting
MAX_EMAILS_PER_HOUR=10
MAX_POSTS_PER_DAY=5

---

# TESTING & DEVELOPMENT

# Use test credentials (set to true during testing)
USE_TEST_CREDENTIALS=false

# Debug mode (verbose logging)
DEBUG_MODE=false

# Dry run (don't actually send/post)
DRY_RUN=false

---

# FIRST-TIME SETUP CHECKLIST

## Before using this .env:

- [ ] Copy this file to .env
- [ ] Generate Gmail OAuth credentials (see README.md)
- [ ] Create WhatsApp session (first login will scan QR code)
- [ ] Get LinkedIn credentials (if using API)
- [ ] Setup email sending credentials (Gmail or SMTP)
- [ ] Create ~/.secrets/ directory for credential files
- [ ] Never commit .env to git
- [ ] Set file permissions: chmod 600 .env
- [ ] Test each watcher individually before enabling scheduling

## How to get each credential:

### Gmail OAuth:
1. Go to https://console.cloud.google.com/
2. Create project → Enable Gmail API → Create OAuth2 credentials
3. Download as JSON → Save to ~/.secrets/gmail_credentials.json

### WhatsApp:
1. First run of watcher will prompt for QR code scan
2. Scan with phone camera
3. Session saved to WHATSAPP_SESSION_PATH

### LinkedIn:
1. Email/password: Use your LinkedIn login
2. API: Apply for access at https://www.linkedin.com/developers

### Email Sending (SMTP):
1. Gmail: Enable 2FA, create app-specific password
2. Outlook: Use regular password or app-specific password
3. SendGrid: Get API key from https://sendgrid.com/

---

# SECURITY REMINDER

✅ DO:
- Store sensitive credentials in .env only
- Use app-specific passwords (not main account password)
- Rotate credentials regularly
- Keep ~/.secrets/ directory secure (chmod 600)

❌ DON'T:
- Commit .env to git
- Hardcode credentials in Python files
- Share .env with others
- Use test credentials in production

---

# Questions?

See Silver Tier/README.md (when complete) for detailed setup instructions.
